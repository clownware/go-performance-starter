# Template for environment variables. Copy to .env and fill in real values.
# Every key here maps to internal/config/config.go — commented keys have
# working compiled-in defaults; only set them to override.

# ── App ──
ENV=development                  # development | test | staging | production (JSON logs when production)
HTTP_PORT=4000
# LOG_LEVEL=info                 # debug | info | warn | error (ADR-026)

# ── Database ──
# Local dev: `task db:up` starts this Postgres, then `task db:test:setup`
# applies the auth.uid() stub and migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alpine_saas?sslmode=disable
# NOTE: if the password contains special characters it MUST be URL-encoded,
# or pgx fails at boot with "net/url: invalid userinfo".

# Pool tuning (optional; ADR-025 defaults shown)
# DB_MAX_CONNS=25
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME=30m
# DB_MAX_CONN_IDLE_TIME=5m

# ── Supabase ──
# Dashboard → Project Settings → API Keys. Set both or neither (auth is
# disabled when both are empty).
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Only needed for the guest-mode reaper (admin user deletion, ADR-024).
# SUPABASE_SERVICE_ROLE_KEY=

# ── Security / ops ──
# When set, /metrics requires "Authorization: Bearer <token>". When unset,
# /metrics is open in development and hidden (404) in production.
# METRICS_TOKEN=

# Trusted proxy networks (ADR-027): comma-separated CIDRs whose
# X-Forwarded-For / X-Real-IP are honored for client-IP resolution. Empty
# (default) trusts NO forwarded headers — fails closed against IP spoofing.
# Set to your edge proxy's egress ranges in production.
# TRUSTED_PROXY_CIDRS=173.245.48.0/20,103.21.244.0/22

# Max request body size in bytes accepted before a handler reads it.
# MAX_REQUEST_BODY_BYTES=1048576

# ── Guest mode (ADR-024) ──
# Requires "anonymous sign-ins" enabled in the Supabase project settings.
# GUEST_MODE_ENABLED=false
# GUEST_TTL=720h                 # unupgraded guest accounts reaped after this age
# REAPER_INTERVAL=1h             # how often the reaper pass runs
