# App configuration
ENV=development
HTTP_PORT=4000

# Database configuration (Phase 1)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alpine_saas?sslmode=disable

# Authentication (Phase 6)
JWT_SECRET=your-development-secret-change-in-production

# Email configuration (Phase 4-5)
EMAIL_SENDER=noreply@example.com
EMAIL_FROM_NAME=Alpine SaaS App

# Supabase configuration (Phase 1, 6)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe configuration (Optional - Phase 4)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
