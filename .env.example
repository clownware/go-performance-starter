# This file is a template for environment variables. Copy to .env and fill in real values.
# App configuration
ENV=development
HTTP_PORT=8080

# Logging (ADR-026): debug | info | warn | error. JSON output when ENV=production.
# LOG_LEVEL=info

# Database configuration (Phase 1)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alpine_saas?sslmode=disable

# Database pool tuning (optional; ADR-025 defaults shown)
# DB_MAX_CONNS=25
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME=30m
# DB_MAX_CONN_IDLE_TIME=5m

# Metrics endpoint guard: when set, /metrics requires "Authorization: Bearer <token>".
# When unset, /metrics is open in development and hidden (404) in production.
# METRICS_TOKEN=

# Trusted proxy networks (ADR-027): comma-separated CIDRs whose X-Forwarded-For /
# X-Real-IP headers are honored for client-IP resolution (rate limiting, logging).
# Empty (default) trusts NO forwarded headers — the direct peer IP is used, which
# fails closed against IP spoofing. Set to your edge proxy's egress ranges in
# production (e.g. Cloudflare's published IP ranges) so per-client limits work.
# TRUSTED_PROXY_CIDRS=173.245.48.0/20,103.21.244.0/22

# Max request body size in bytes accepted before a handler reads it (default 1 MiB).
# MAX_REQUEST_BODY_BYTES=1048576

# Guest mode (ADR-024): anonymous Supabase identities for visitors.
# Requires "anonymous sign-ins" enabled in the Supabase project settings.
# GUEST_MODE_ENABLED=false
# GUEST_TTL=720h          # unupgraded guest accounts are reaped after this age
# REAPER_INTERVAL=1h      # how often the reaper pass runs

# Supabase Credentials
SUPABASE_URL="YOUR_SUPABASE_URL"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# Optional: Service Role Key for backend operations
# SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Authentication (Phase 6)
JWT_SECRET=your-development-secret-change-in-production

# Email configuration (Phase 4-5)
EMAIL_SENDER=noreply@example.com
EMAIL_FROM_NAME=Alpine SaaS App

# Stripe configuration (Optional - Phase 4)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
